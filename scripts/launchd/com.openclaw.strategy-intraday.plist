<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.strategy-intraday</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>-m</string>
        <string>pipelines.insider_study.simulate_portfolio_intraday</string>
        <string>--all</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/derekg/trading-framework</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>PYTHONPATH</key>
        <string>/Users/derekg/trading-framework</string>
    </dict>
    <!-- Fires every 10 min around the clock. The script self-gates on
         market hours (06:30 - 13:00 PT Mon-Fri); outside-hours fires
         no-op after a sub-second check.
         Market open (06:30 PT) gets a normal fire that picks up
         overnight/weekend filings backlog. -->
    <key>StartInterval</key>
    <integer>600</integer>
    <key>RunAtLoad</key>
    <false/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/Users/derekg/trading-framework/logs/strategy-intraday.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/derekg/trading-framework/logs/strategy-intraday.log</string>
</dict>
</plist>
