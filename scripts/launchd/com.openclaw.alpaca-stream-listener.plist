<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.alpaca-stream-listener</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>-m</string>
        <string>framework.oms.alpaca_stream_listener</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/derekg/trading-framework</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>PYTHONPATH</key>
        <string>/Users/derekg/trading-framework</string>
    </dict>
    <!-- Long-running daemon that subscribes to Alpaca's trade_updates
         WebSocket on all paper account credentials. Updates order_audit
         + strategy_portfolio in real time as fills/rejections arrive.
         KeepAlive restarts it if it ever exits cleanly or crashes;
         exponential backoff is in the script itself for connection drops. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>/Users/derekg/trading-framework/logs/alpaca-stream-listener.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/derekg/trading-framework/logs/alpaca-stream-listener.log</string>
</dict>
</plist>
