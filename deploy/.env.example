ALPACA_API_SECRET=

# ─── App URLs ────────────────────────────────────────
# Dev:  http://localhost:3000 / http://localhost:8000/api/v1
# Prod: https://form4.app / https://form4.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000

# ─── Docker volume paths (prod only) ────────────────
# Point these to the host directories containing the SQLite DBs.
# Scrapers running on the host write to these; the API container reads them.
INSIDERS_DB_DIR=/Users/openclaw/trading-framework/strategies/insider_catalog
NOTIFICATIONS_DB_DIR=/Users/openclaw/trading-framework/api
