# ─── Clerk ───────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN/.well-known/jwks.json
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_API_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_API_MONTHLY_PRICE_ID=

# ─── Resend (email) ─────────────────────────────────
RESEND_API_KEY=

# ─── Alpaca ──────────────────────────────────────────
# Shared READ-ONLY data credentials. Used by data readers (bars/snapshots/quotes).
# NEVER use for order execution — trading runners read ALPACA_API_KEY_{PREFIX}
# (prefix declared in each strategy yaml as `alpaca_env_prefix`).
ALPACA_DATA_API_KEY=
ALPACA_DATA_API_SECRET=

# Trading credentials — one dedicated paper account per productized strategy.
# Max 3 strategies. Never commingle two strategies on the same pair.
ALPACA_API_KEY_QUALITY_MOMENTUM=
ALPACA_API_SECRET_QUALITY_MOMENTUM=
ALPACA_API_KEY_REVERSAL_DIP=
ALPACA_API_SECRET_REVERSAL_DIP=
ALPACA_API_KEY_TENB51_SURPRISE=
ALPACA_API_SECRET_TENB51_SURPRISE=

# ─── App URLs ────────────────────────────────────────
# Dev:  http://localhost:3000 / http://localhost:8000/api/v1
# Prod: https://form4.app / https://form4.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000

# ─── Docker volume paths (prod only) ────────────────
# Point these to the host directories containing the SQLite DBs.
# Scrapers running on the host write to these; the API container reads them.
INSIDERS_DB_DIR=/Users/openclaw/trading-framework/strategies/insider_catalog
NOTIFICATIONS_DB_DIR=/Users/openclaw/trading-framework/api
